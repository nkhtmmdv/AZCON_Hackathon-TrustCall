# GEMINI_API_KEY: Required for Gemini AI API calls (SERVER-SIDE ONLY — never expose to client).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=your-gemini-api-key

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for CORS origin allowlist, OAuth callbacks, and API endpoints.
APP_URL="https://your-app-url.example.com"

# API
API_PORT=5175

# REQUIRED: Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use a short or guessable value in production.
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET

# Superadmin credentials — set securely via environment, never commit real values.
SUPERADMIN_EMAIL=admin@azercell.com
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional: override API base URL for the frontend (leave empty to use relative path)
VITE_API_BASE_URL=

